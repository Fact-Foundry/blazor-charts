<nav style="width: 200px; background: var(--nav-bg); padding: 1rem; color: white;">
    <h3 style="margin: 0 0 1rem; font-size: 1rem;">Charts Demo</h3>
    <ul style="list-style: none; padding: 0; margin: 0;">
        <li style="margin-bottom: 0.5rem;">
            <NavLink href="" Match="NavLinkMatch.All" style="color: var(--nav-text); text-decoration: none;">Home</NavLink>
        </li>
        <li style="margin-bottom: 0.5rem;">
            <NavLink href="line-chart" style="color: var(--nav-text); text-decoration: none;">Line Chart</NavLink>
        </li>
        <li style="margin-bottom: 0.5rem;">
            <NavLink href="donut-chart" style="color: var(--nav-text); text-decoration: none;">Donut Chart</NavLink>
        </li>
        <li style="margin-bottom: 0.5rem;">
            <NavLink href="pie-chart" style="color: var(--nav-text); text-decoration: none;">Pie Chart</NavLink>
        </li>
    </ul>
    <button class="theme-toggle" @onclick="OnToggleTheme">@(IsDark ? "Light Mode" : "Dark Mode")</button>
</nav>

@code {
    [Parameter] public bool IsDark { get; set; }
    [Parameter] public EventCallback OnToggleTheme { get; set; }
}
