@page "/world-map"
@rendermode InteractiveServer

<h2>World Map Chart</h2>

<div style="margin-bottom: 1rem;">
    <label><input type="checkbox" @bind="showLegend" /> Show Legend</label>
    <label style="margin-left: 1rem;">Color scheme:</label>
    <select @bind="colorScheme" style="margin-left: 0.25rem;">
        <option value="blue">Blue</option>
        <option value="heat">Heat (Yellow → Red)</option>
        <option value="green">Green</option>
        <option value="purple">Purple</option>
    </select>
</div>

<h3>Users by Country</h3>
<WorldMapChart Title="Active Users"
               Data="@userData"
               ColorScale="@GetColorScale()"
               ShowLegend="showLegend"
               Width="900"
               Height="450" />

<h3 style="margin-top: 2rem;">GDP per Capita</h3>
<WorldMapChart Title="GDP per Capita (USD)"
               Data="@gdpData"
               ColorScale="@(new[] { "#fef3c7", "#d97706", "#7c2d12" })"
               ShowLegend="showLegend"
               Width="900"
               Height="450" />

@code {
    private bool showLegend = true;
    private string colorScheme = "blue";

    private string[] GetColorScale() => colorScheme switch
    {
        "heat" => ["#fef08a", "#f97316", "#dc2626"],
        "green" => ["#dcfce7", "#16a34a"],
        "purple" => ["#f3e8ff", "#7c3aed"],
        _ => ["#dbeafe", "#2563eb"],
    };

    private List<MapDataPoint> userData =
