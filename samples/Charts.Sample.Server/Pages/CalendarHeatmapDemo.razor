@page "/calendar-heatmap"
@rendermode InteractiveServer

<h2>Calendar Heatmap</h2>

<p style="max-width: 640px; opacity: .8;">
    A GitHub-contributions-style grid — one cell per day, colored by intensity. Hover a
    day for its date and value; click to select. Feed it a flat list of
    <code>CalendarPoint</code> (day + value); same-day points are summed.
</p>

<div style="margin-bottom: 1rem;">
    <label>Week starts:
        <select @bind="weekStart" style="margin-left:.25rem;">
            <option value="Sunday">Sunday</option>
            <option value="Monday">Monday</option>
        </select>
    </label>
    <label style="margin-left: 1rem;">Levels:
        <select @bind="levels" style="margin-left:.25rem;">
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
        </select>
    </label>
    <label style="margin-left: 1rem;"><input type="checkbox" @bind="showLegend" /> Legend</label>
</div>

<div style="max-width: 860px; border: 1px solid rgba(128,128,128,.25); border-radius: 8px; padding: 12px;">
    <CalendarHeatmap Data="@data"
                     WeekStart="weekStart"
                     Levels="levels"
                     ShowLegend="showLegend"
                     ValueFormat="N0"
                     OnDayClick="d => selected = d" />
</div>

@if (selected is not null)
{
    <p style="margin-top: 1rem;">
        Selected: <strong>@selected.Date.ToString("MMM d, yyyy")</strong> — @selected.Value.ToString("N0") commits
    </p>
}

@code {
    private DayOfWeek weekStart = DayOfWeek.Sunday;
    private int levels = 4;
    private bool showLegend = true;
    private CalendarPoint? selected;

    private readonly List<CalendarPoint> data = BuildYear();

    // One year of synthetic "commits per day": busier on weekdays, quiet weekends, some
    // days off entirely. Seeded so the demo renders the same every time.
    private static List<CalendarPoint> BuildYear()
    {
        var rnd = new Random(7);
        var list = new List<CalendarPoint>();
        var start = new DateOnly(2025, 8, 1);
        for (var i = 0; i < 365; i++)
        {
            var d = start.AddDays(i);
            var weekend = d.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
            var v = rnd.Next(0, weekend ? 4 : 12);
            if (rnd.Next(0, 6) == 0) v = 0; // days off
            if (v > 0) list.Add(new CalendarPoint { Date = d, Value = v });
        }
        return list;
    }
}
