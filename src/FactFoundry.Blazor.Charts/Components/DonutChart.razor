@namespace FactFoundry.Blazor.Charts.Components

<svg width="@(Responsive ? "100%" : $"{Width}")"
     height="@(Responsive ? null : $"{Height}")"
     viewBox="@(Responsive ? $"0 0 {Width} {Height}" : null)"
     preserveAspectRatio="@(Responsive ? "xMidYMid meet" : null)"
     xmlns="http://www.w3.org/2000/svg" role="img">
    @if (!string.IsNullOrEmpty(Title))
    {
        <title>@Title</title>
        @((MarkupString)$"<text x=\"{Width / 2}\" y=\"20\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"bold\" fill=\"{ResolvedTheme.TextColor}\">{Title}</text>")
    }

    @* Donut segments *@
    @for (var i = 0; i < EffectiveData.Count; i++)
    {
        var idx = i;
        var color = GetSegmentColor(i);
        <path d="@BuildSegmentPath(i)" fill="@color"
              fill-opacity="@(_hoveredIndex == i ? "1" : "0.85")"
              @onmouseover="() => OnSegmentMouseOver(idx)"
              @onmouseout="OnSegmentMouseOut"
              style="cursor: pointer; transition: fill-opacity 0.15s;" />
    }

    @* Leader line labels *@
    @if (ShowLabels)
    {
        var resolvedLabels = GetResolvedLabels();
        @foreach (var lbl in resolvedLabels)
        {
            <line x1="@lbl.EdgeX.ToString("F1")" y1="@lbl.EdgeY.ToString("F1")"
                  x2="@lbl.ElbowX.ToString("F1")" y2="@lbl.ElbowY.ToString("F1")"
                  stroke="@lbl.Color" stroke-width="1" />
            <line x1="@lbl.ElbowX.ToString("F1")" y1="@lbl.ElbowY.ToString("F1")"
                  x2="@lbl.EndX.ToString("F1")" y2="@lbl.EndY.ToString("F1")"
                  stroke="@lbl.Color" stroke-width="1" />
            <circle cx="@lbl.EndX.ToString("F1")" cy="@lbl.EndY.ToString("F1")" r="2" fill="@lbl.Color" />
            @((MarkupString)$"<text x=\"{(lbl.Anchor == "start" ? lbl.EndX + 4 : lbl.EndX - 4).ToString("F1")}\" y=\"{(lbl.EndY + 4).ToString("F1")}\" text-anchor=\"{lbl.Anchor}\" font-size=\"10\" fill=\"{ResolvedTheme.TextColor}\">{lbl.Text}</text>")
        }
    }

    @* Center label *@
    @if (!string.IsNullOrEmpty(CenterLabel))
    {
        @((MarkupString)$"<text x=\"{CenterX.ToString("F1")}\" y=\"{(CenterY - 6).ToString("F1")}\" text-anchor=\"middle\" font-size=\"11\" fill=\"{ResolvedTheme.TextColor}\" opacity=\"{ResolvedTheme.LabelOpacity.ToString("F2")}\">{CenterLabel}</text>")
        @((MarkupString)$"<text x=\"{CenterX.ToString("F1")}\" y=\"{(CenterY + 12).ToString("F1")}\" text-anchor=\"middle\" font-size=\"16\" font-weight=\"bold\" fill=\"{ResolvedTheme.TextColor}\">{Total.ToString("N0")}</text>")
    }

    @* Hover tooltip (only when labels are off) *@
    @if (!ShowLabels && _hoveredIndex is not null)
    {
        var segment = EffectiveData[_hoveredIndex.Value];
        var midAngleRad = GetMidAngle(_hoveredIndex.Value) * Math.PI / 180;
        var tooltipX = CenterX + (OuterRadius + 20) * Math.Cos(midAngleRad);
        var tooltipY = CenterY + (OuterRadius + 20) * Math.Sin(midAngleRad);
        var anchor = Math.Cos(midAngleRad) >= 0 ? "start" : "end";
        @((MarkupString)$"<text x=\"{tooltipX.ToString("F1")}\" y=\"{tooltipY.ToString("F1")}\" text-anchor=\"{anchor}\" font-size=\"11\" fill=\"{ResolvedTheme.TextColor}\">{segment.Label}: {segment.Value:N0} ({GetPercentage(_hoveredIndex.Value)})</text>")
    }

    @* Legend *@
    @if (ShowLegend)
    {
        var legendX = Width - LegendWidth + 10;
        @for (var i = 0; i < EffectiveData.Count; i++)
        {
            var legendY = 40 + i * 22;
            var color = GetSegmentColor(i);
            <rect x="@legendX" y="@(legendY - 8)" width="10" height="10" rx="2" fill="@color" />
            @((MarkupString)$"<text x=\"{legendX + 14}\" y=\"{legendY}\" font-size=\"10\" fill=\"{ResolvedTheme.TextColor}\">{GetLegendText(i)}</text>")
        }
    }
</svg>
