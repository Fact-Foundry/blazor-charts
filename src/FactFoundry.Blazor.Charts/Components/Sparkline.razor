@namespace FactFoundry.Blazor.Charts.Components

@{
    var pts = Points();
}

@if (pts.Count > 0)
{
    <svg viewBox="0 0 @Width @Height"
         width="@(Responsive ? "100%" : Width.ToString())"
         height="@(Responsive ? null : Height.ToString())"
         preserveAspectRatio="none" role="img" aria-labelledby="@TitleId @DescId"
         style="display:block;overflow:visible;">
        <title id="@TitleId">@AccessibleName</title>
        <desc id="@DescId">@AccessibleDescription</desc>
        @if (ShowArea)
        {
            <defs>
                <linearGradient id="@_gradientId" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0" stop-color="@Stroke" stop-opacity="0.28" />
                    <stop offset="1" stop-color="@Stroke" stop-opacity="0" />
                </linearGradient>
            </defs>
            <path d="@AreaPath(pts)" fill="url(#@_gradientId)" />
        }
        <path d="@LinePath(pts)" fill="none" stroke="@Stroke"
              stroke-width="@StrokeWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)"
              stroke-linejoin="round" stroke-linecap="round" />
        @if (ShowEndDot)
        {
            <circle cx="@F(pts[^1].X)" cy="@F(pts[^1].Y)" r="1.8" fill="@Stroke" />
        }
    </svg>
}
